# ============================================================
# [overfit-checker] 환경 설정 템플릿
# 복사: cp .env.example .env 후 실제 값으로 채워주세요
# 주의: .env 파일은 절대 git에 커밋하지 마세요
# ============================================================

# LLM 엔드포인트 (OpenAI-compatible)
# 기본값: Govail LiteLLM 게이트웨이
# 직접 OpenAI 사용 시: https://api.openai.com/v1
LLM_BASE_URL=http://localhost:14000/v1

# API 키
# Govail 게이트웨이 사용 시: govail-demo-admin
# OpenAI 직접 사용 시: sk-...
LLM_API_KEY=govail-demo-admin

# 사용할 모델
# Govail 게이트웨이: mock-model (데모), auto (라우팅)
# OpenAI 직접: gpt-4o-mini, gpt-4o
LLM_MODEL=gpt-4o-mini
