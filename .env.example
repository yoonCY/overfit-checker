# ============================================================
# [overfit-checker] 환경 설정 템플릿
# 복사: cp .env.example .env 후 실제 값으로 채워주세요
# 주의: .env 파일은 절대 git에 커밋하지 마세요
# ============================================================

# LLM 엔드포인트 (OpenAI-compatible)
# 기본값: Govail Gateway (macmini)
# 직접 OpenAI 사용 시: https://api.openai.com/v1
LLM_BASE_URL=http://localhost:8080/v1

# JWT 서명용 대칭키 (필수 설정)
# 고베일 게이트웨이 인증을 위한 프로젝트별 전용 JWT Secret 대칭키
# (Code Analyzer Admin API를 통해 발급받은 비밀키 주입)
JWT_SECRET=your-shared-jwt-secret-here

# 사용할 모델
# Govail 게이트웨이: auto (라우팅), mock-model (데모)
# OpenAI 직접: gpt-4o-mini, gpt-4o
LLM_MODEL=auto
